---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  role?: string | null;
  image?: ImageMetadata | null;
  district?: string | null;
  council?: string | null;
  councilUrl?: string | null;
  appointedBy?: string | null;
  appointedByUrl?: string | null;
  variant?: 'default' | 'memorial';
  vacant?: boolean;
}

const {
  name,
  role,
  image,
  district,
  council,
  councilUrl,
  appointedBy,
  appointedByUrl,
  variant = 'default',
  vacant = false,
} = Astro.props;

const initials = vacant
  ? '?'
  : name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();

const isMemorial = variant === 'memorial';
---

<div class:list={[
  'border border-border rounded-lg p-4 flex items-start gap-4',
  isMemorial && 'bg-gray-50',
]}>
  {!isMemorial && (
    <div class="shrink-0">
      {image ? (
        <Image
          src={image}
          alt={vacant ? 'Vacant seat' : `Photo of ${name}`}
          width={160}
          height={160}
          class:list={[
            'rounded-full object-cover w-16 h-16 sm:w-20 sm:h-20',
            vacant && 'opacity-40',
          ]}
        />
      ) : (
        <div class:list={[
          'w-16 h-16 sm:w-20 sm:h-20 rounded-full flex items-center justify-center text-lg font-semibold',
          vacant
            ? 'bg-gray-200 text-text-muted/50'
            : 'bg-primary/10 text-primary',
        ]}>
          {initials}
        </div>
      )}
    </div>
  )}

  <div class="min-w-0">
    <h3 class:list={[
      'font-semibold',
      vacant ? 'text-text-muted italic' : 'text-primary',
    ]}>
      {vacant ? 'Vacant' : name}
    </h3>

    {role && (
      <p class="text-sm text-text-muted">{role}</p>
    )}

    {district && (
      <p class="text-xs text-text-muted mt-1">
        {councilUrl ? (
          <a href={councilUrl} class="text-primary hover:underline" target="_blank" rel="noopener">
            {district}
          </a>
        ) : (
          <span>{district}</span>
        )}
        {council && <span> &mdash; CM {council}</span>}
      </p>
    )}

    {appointedBy && (
      <p class="text-xs text-text-muted mt-1">
        Appointed by{' '}
        {appointedByUrl ? (
          <a href={appointedByUrl} class="text-primary hover:underline" target="_blank" rel="noopener">
            {appointedBy}
          </a>
        ) : (
          <span>{appointedBy}</span>
        )}
      </p>
    )}
  </div>
</div>
