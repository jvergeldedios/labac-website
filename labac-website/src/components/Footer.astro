---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-gray-50 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h2 class="text-lg font-bold text-primary mb-2">LABAC</h2>
        <p class="text-sm text-text-muted">
          An advisory body to the City of Los Angeles on bicycle transportation since 1975.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text mb-2">Quick Links</h3>
        <ul class="space-y-1 text-sm">
          <li><a href="/meetings" class="text-text-muted hover:text-primary">Meeting Schedule</a></li>
          <li><a href="/get-involved" class="text-text-muted hover:text-primary">Get Involved</a></li>
          <li><a href="/news" class="text-text-muted hover:text-primary">News & Updates</a></li>
          <li><a href="/contact" class="text-text-muted hover:text-primary">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text mb-2">Contact</h3>
        <p class="text-sm text-text-muted">
          Meetings held at Los Angeles City Hall<br />
          200 N Spring St, Los Angeles, CA 90012
        </p>
      </div>
    </div>
    <div class="mt-8 pt-4 border-t border-border text-center text-xs text-text-muted">
      &copy; {currentYear} Los Angeles Bicycle Advisory Committee. All rights reserved.
    </div>
  </div>
</footer>
