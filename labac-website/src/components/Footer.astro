---
import { url } from '../utils/paths';
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-gray-50 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h2 class="text-lg font-bold text-primary mb-2">LABAC</h2>
        <p class="text-sm text-text-muted mb-3">
          An advisory body to the City of Los Angeles on bicycle transportation since 1973.
        </p>
        <div class="flex gap-4 text-sm">
          <a href="https://www.facebook.com/LosAngelesBicycleAdvisoryCommittee/" class="text-text-muted hover:text-primary" target="_blank" rel="noopener">Facebook</a>
          <a href="https://twitter.com/BicycleLACity/media" class="text-text-muted hover:text-primary" target="_blank" rel="noopener">Twitter</a>
          <a href="https://www.instagram.com/bicyclelacity/" class="text-text-muted hover:text-primary" target="_blank" rel="noopener">Instagram</a>
          <a href="https://www.youtube.com/channel/UC1TcSpr0y6BHDXJqAS9iaSQ" class="text-text-muted hover:text-primary" target="_blank" rel="noopener">YouTube</a>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text mb-2">Quick Links</h3>
        <ul class="space-y-1 text-sm">
          <li><a href={url('/meetings')} class="text-text-muted hover:text-primary">Meeting Schedule</a></li>
          <li><a href={url('/get-involved')} class="text-text-muted hover:text-primary">Get Involved</a></li>
          <li><a href={url('/resources')} class="text-text-muted hover:text-primary">Resources</a></li>
          <li><a href={url('/contact')} class="text-text-muted hover:text-primary">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-text mb-2">Meetings</h3>
        <p class="text-sm text-text-muted">
          Hollywood Neighborhood City Hall<br />
          6501 Fountain Avenue<br />
          Los Angeles, CA 90028
        </p>
        <p class="text-sm text-text-muted mt-2">
          Public comment: <a href="mailto:robkadota@gmail.com" class="text-primary hover:underline">robkadota@gmail.com</a>
        </p>
      </div>
    </div>
    <div class="mt-8 pt-4 border-t border-border text-center text-xs text-text-muted">
      &copy; {currentYear} Los Angeles Bicycle Advisory Committee. All rights reserved.
    </div>
  </div>
</footer>
