---
import PageLayout from '../layouts/PageLayout.astro';
import MemberCard from '../components/MemberCard.astro';
import type { ImageMetadata } from 'astro';

// Load all member images at build time
const memberImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/members/*.{png,jpg,jpeg,webp}',
  { eager: true }
);

function getMemberImage(name: string): ImageMetadata | null {
  const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  for (const [key, mod] of Object.entries(memberImages)) {
    const filename = key.split('/').pop()?.replace(/\.[^.]+$/, '');
    if (filename === slug) return mod.default;
  }
  return null;
}

const mayoralAppointees = [
  { name: 'Eli Akira Kaufman', role: 'Member' },
  { name: 'Glenn Bailey', role: 'Member' },
  { name: 'Karen Canady', role: 'Member' },
  { name: 'Rob Kadota', role: 'Chairperson' },
];

const districtMembers = [
  { district: 1, council: 'Eunisses Hernandez', rep: 'Jennifer Gill', role: 'Vice Chairperson & Bikeway Engineering Chair', url: 'http://cd1.lacity.org/' },
  { district: 2, council: 'Paul Krekorian', rep: null, role: null, url: 'http://cd2.lacity.org/' },
  { district: 3, council: 'Bob Blumenfield', rep: 'Janis Hatlestad', role: 'Member', url: 'http://cd3.lacity.org/' },
  { district: 4, council: 'Nithya Raman', rep: 'Curtis Graham', role: 'Member', url: 'http://cd4.lacity.org/' },
  { district: 5, council: 'Katy Yaroslavsky', rep: 'Michael Schneider', role: 'Member', url: 'https://councildistrict5.lacity.gov/' },
  { district: 6, council: 'Imelda Padilla', rep: 'Lionel Mares', role: 'Member', url: 'http://cd6.lacity.org/' },
  { district: 7, council: 'Monica Rodriguez', rep: 'John Laue', role: 'Member', url: 'http://cd7.lacity.org/' },
  { district: 8, council: 'Marqueece Harris-Dawson', rep: 'Aubrey Provost', role: 'Member', url: 'http://cd8.lacity.org/' },
  { district: 9, council: 'Curren D. Price, Jr.', rep: 'Ade Neff', role: 'Member', url: 'http://cd9.lacity.org/' },
  { district: 10, council: 'Heather Hutt', rep: null, role: null, url: 'https://councildistrict10.lacity.gov/' },
  { district: 11, council: 'Traci Park', rep: 'Julian Vergel de Dios', role: 'Member', url: 'https://councildistrict11.lacity.gov/' },
  { district: 12, council: 'John Lee', rep: null, role: null, url: 'http://cd12.lacity.org/' },
  { district: 13, council: 'Hugo Soto-Martinez', rep: 'Philip Armstrong', role: 'Member', url: 'http://cd13.lacity.org/' },
  { district: 14, council: 'Kevin De Leon', rep: null, role: null, url: 'http://cd14.lacity.org/' },
  { district: 15, council: 'Tim McOsker', rep: null, role: null, url: 'http://cd15.lacity.org/' },
];

const alternates = [
  { name: 'Danny Duarte', district: 'CD 3' },
  { name: 'Taylor Nichols', district: 'CD 5' },
];

const inMemory = [
  { name: 'Alex Baum', role: 'Founder & Chair Emeritus', dates: 'Dec 30, 1922 \u2013 Mar 1, 2015' },
  { name: 'Dana Sherman', role: 'CD 3', dates: 'Died November 20, 2019' },
];
---

<PageLayout title="Committee Members" description="Meet the current members of the Los Angeles Bicycle Advisory Committee.">
  <p class="text-lg text-text-muted mb-6">
    Los Angeles Bicycle Advisory Committee (BAC) members are appointed by each City Council office and the Office of the Mayor.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-4">Mayoral Appointees</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
    {mayoralAppointees.map((m) => (
      <MemberCard
        name={m.name}
        role={m.role}
        image={getMemberImage(m.name)}
        appointedBy="Office of the Mayor"
        appointedByUrl="https://www.lamayor.org/"
      />
    ))}
  </div>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-4">Council District Appointees</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
    {districtMembers.map((d) => (
      <MemberCard
        name={d.rep || `CD ${d.district}`}
        role={d.role}
        image={d.rep ? getMemberImage(d.rep) : null}
        district={`CD ${d.district}`}
        council={d.council}
        councilUrl={d.url}
        vacant={!d.rep}
      />
    ))}
  </div>

  <p class="text-sm text-text-muted mb-8">
    <a href="https://empowerla.org/council-districts-map/" class="text-primary hover:underline" target="_blank" rel="noopener">View Map of City Council Districts</a>
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-4">Alternates</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
    {alternates.map((a) => (
      <MemberCard
        name={a.name}
        image={getMemberImage(a.name)}
        district={a.district}
      />
    ))}
  </div>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-4">In Memory</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {inMemory.map((m) => (
      <MemberCard
        name={m.name}
        role={`${m.role} \u2014 ${m.dates}`}
        variant="memorial"
      />
    ))}
  </div>
</PageLayout>
