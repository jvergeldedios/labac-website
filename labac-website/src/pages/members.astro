---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const members = await getCollection('members');
const sortedMembers = members.sort((a, b) => a.data.district - b.data.district);
---

<PageLayout title="Current Members" description="Meet the current members of the Los Angeles Bicycle Advisory Committee.">
  <p class="text-lg text-text-muted mb-6">
    LABAC members are appointed by City Council members, with each council district represented on the committee.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {sortedMembers.map((member) => (
      <div class="border border-border rounded-lg p-4">
        <h2 class="font-semibold text-primary">{member.data.name}</h2>
        <p class="text-sm text-text-muted">District {member.data.district}</p>
        {member.data.role && <p class="text-sm text-accent font-medium">{member.data.role}</p>}
        {member.data.appointedBy && <p class="text-xs text-text-muted mt-1">Appointed by {member.data.appointedBy}</p>}
        {member.data.term && <p class="text-xs text-text-muted">Term: {member.data.term}</p>}
      </div>
    ))}
  </div>
</PageLayout>
