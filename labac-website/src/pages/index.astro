---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Los Angeles Bicycle Advisory Committee — advising the City of LA on bicycle transportation since 1975.">
  <section class="bg-primary text-white py-12">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-4">Los Angeles Bicycle Advisory Committee</h1>
      <p class="text-lg text-white/80 mb-6">Advising the City of Los Angeles on bicycle transportation since 1975</p>
      <div class="bg-white/10 rounded-lg p-6 inline-block">
        <p class="text-sm uppercase tracking-wide text-white/70 mb-1">Next Meeting</p>
        <p class="text-2xl font-bold">Coming Soon</p>
        <p class="text-sm text-white/70 mt-1">City Hall, 200 N Spring St, Los Angeles</p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/get-involved" class="block p-6 border border-border rounded-lg hover:border-primary hover:shadow-sm transition-all">
        <h2 class="text-lg font-semibold text-primary mb-2">Get Involved</h2>
        <p class="text-sm text-text-muted">Attend meetings, submit public comment, or apply to join the committee.</p>
      </a>
      <a href="/meetings" class="block p-6 border border-border rounded-lg hover:border-primary hover:shadow-sm transition-all">
        <h2 class="text-lg font-semibold text-primary mb-2">Meetings</h2>
        <p class="text-sm text-text-muted">View the schedule, agendas, and minutes from past meetings.</p>
      </a>
      <a href="/news" class="block p-6 border border-border rounded-lg hover:border-primary hover:shadow-sm transition-all">
        <h2 class="text-lg font-semibold text-primary mb-2">News & Updates</h2>
        <p class="text-sm text-text-muted">Stay up to date on committee actions and LA cycling news.</p>
      </a>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-primary mb-4">About LABAC</h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        The Los Angeles Bicycle Advisory Committee (LABAC) advises the City of Los Angeles on policies, programs, and projects that affect bicycle transportation. Established in 1975, we work to make cycling safer and more accessible for all Angelenos.
      </p>
      <a href="/about" class="inline-block mt-4 text-primary font-medium hover:underline">Learn more &rarr;</a>
    </div>
  </section>
</BaseLayout>
