---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout title="Resources" description="Bicycle transportation resources for Los Angeles.">
  <p class="text-lg text-text-muted mb-6">
    Useful resources for cycling in Los Angeles.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">City Plans & Policies</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
    <li>Los Angeles Mobility Plan 2035</li>
    <li>LA City Bicycle Plan</li>
    <li>Vision Zero Los Angeles</li>
  </ul>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Bicycle Classifications</h2>
  <p class="text-text-muted mb-4">
    Information about Class I, II, III, and IV bicycle facilities coming soon.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Related Organizations</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2">
    <li>Los Angeles Department of Transportation (LADOT)</li>
    <li>Metro — Los Angeles County Metropolitan Transportation Authority</li>
    <li>Los Angeles County Bicycle Coalition (LACBC)</li>
  </ul>

  <p class="mt-8 text-text-muted">
    For safety-specific resources, visit our <a href="/resources/safety" class="text-primary hover:underline">Safety Resources</a> page.
  </p>
</PageLayout>
