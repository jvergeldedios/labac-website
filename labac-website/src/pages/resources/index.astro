---
import PageLayout from '../../layouts/PageLayout.astro';
import { url } from '../../utils/paths';
---

<PageLayout title="Resources" description="Bicycle transportation resources, guides, and organizations for Los Angeles.">
  <p class="text-lg text-text-muted mb-6">
    Resources for cycling in Los Angeles — from LABAC documents to government agencies and advocacy organizations.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">LABAC Committee Documents</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
    <li><a href={url('/documents/labac/charter.pdf')} class="text-primary hover:underline" target="_blank" rel="noopener">LABAC Charter</a></li>
    <li><a href={url('/documents/labac/strategic-plan-2023.pdf')} class="text-primary hover:underline" target="_blank" rel="noopener">LABAC Strategic Plan 2023</a></li>
    <li><a href={url('/documents/labac/resource-guide.pdf')} class="text-primary hover:underline" target="_blank" rel="noopener">Bicycling Resource Guide A-to-Z</a></li>
    <li><a href={url('/documents/labac/aashto-bike-guide-overview.pdf')} class="text-primary hover:underline" target="_blank" rel="noopener">AASHTO Bike Guide Overview (Part One)</a></li>
  </ul>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Committee Resource Manual</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
    <li><a href="https://ladotlivablestreets.org/content/our-partners" class="text-primary hover:underline" target="_blank" rel="noopener">LADOT Partners and Advisory Committees</a></li>
    <li><a href="https://www.calbike.org/our_initiatives/streets_for_everyone/complete_streets/" class="text-primary hover:underline" target="_blank" rel="noopener">CalBike &mdash; What are Complete Streets</a></li>
    <li><a href="https://www.streetsforall.org/transpo101" class="text-primary hover:underline" target="_blank" rel="noopener">Transportation 101 (Streets for All)</a></li>
    <li><a href="https://ladot.lacity.gov/sites/default/files/2023-05/bilingual-glossary-transportation-terms_2.pdf" class="text-primary hover:underline" target="_blank" rel="noopener">LADOT Glossary of Transportation Terms (bilingual)</a></li>
    <li><a href="https://ladotlivablestreets.org/content-landing/Vision-Zero-Safety-Toolkit" class="text-primary hover:underline" target="_blank" rel="noopener">LADOT Vision Zero Safety Toolkit</a></li>
    <li><a href="https://drive.google.com/file/d/1TCx5VAZ0fCn_2eth7neeGvIiTZKtL_EM/view" class="text-primary hover:underline" target="_blank" rel="noopener">Planning for Stress Free Connections Implementation Guide</a></li>
    <li><a href="https://dot.ca.gov/-/media/dot-media/programs/design/documents/dib-94-010224-a11y.pdf" class="text-primary hover:underline" target="_blank" rel="noopener">Caltrans Complete Streets Design Guidance Bulletin</a></li>
    <li><a href="https://caatpresources.org/" class="text-primary hover:underline" target="_blank" rel="noopener">CalTrans Active Transportation Resource Center</a></li>
    <li><a href="https://highways.dot.gov/media/14126" class="text-primary hover:underline" target="_blank" rel="noopener">FHWA Proven Safety Countermeasures</a></li>
    <li><a href="https://www.transportation.gov/pedestrian-bicycle-safety" class="text-primary hover:underline" target="_blank" rel="noopener">US DOT &mdash; Improving Safety for Walking, Biking, and Rolling</a></li>
  </ul>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Bike Parking Resources</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
    <li><a href="https://labikecommittee.org/wp-content/uploads/2024/07/EssentialsofBikeParking_FINA.pdf" class="text-primary hover:underline" target="_blank" rel="noopener">Essentials of Bike Parking (APBP)</a></li>
    <li><a href="https://labikecommittee.org/wp-content/uploads/2024/07/bike-parking-guide.pdf" class="text-primary hover:underline" target="_blank" rel="noopener">Pocket Guide to Bike Parking (Dero)</a></li>
    <li><a href="https://labikecommittee.org/wp-content/uploads/2024/07/CA_BikeParking_FactSht_FINAL_9-2012.pdf" class="text-primary hover:underline" target="_blank" rel="noopener">CA Bike Parking Factsheet (ChangeLab Solutions)</a></li>
    <li><a href="https://www.youtube.com/watch?v=UPeBwxjxnEo" class="text-primary hover:underline" target="_blank" rel="noopener">Short Term Bike Parking Webinar</a></li>
    <li><a href="https://www.youtube.com/watch?v=S5zBd2DlpnY" class="text-primary hover:underline" target="_blank" rel="noopener">Long Term Bike Parking Webinar</a></li>
  </ul>

