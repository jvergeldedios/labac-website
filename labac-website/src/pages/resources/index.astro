  <div class="mt-8 flex gap-4 text-sm">
    <a href={url('/resources/classifications')} class="text-primary hover:underline">Bicycle Classifications &rarr;</a>
    <a href={url('/resources/clubs')} class="text-primary hover:underline">Bicycle Clubs &rarr;</a>
    <a href={url('/maps')} class="text-primary hover:underline">Maps &amp; Routes &rarr;</a>
  </div>
