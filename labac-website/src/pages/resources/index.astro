    <li><a href="https://www.calbike.org/go_for_a_ride/california_bicycle_laws/" class="text-primary hover:underline" target="_blank" rel="noopener">CalBike &mdash; California Bicycle Laws</a></li>
    <li><a href="https://www.peopleforbikes.org" class="text-primary hover:underline" target="_blank" rel="noopener">People for Bikes</a></li>
  </ul>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Advocacy Organizations</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
    <li><a href="http://www.bicyclekitchen.com/" class="text-primary hover:underline" target="_blank" rel="noopener">Bicycle Kitchen / Bici Cocina</a></li>
    <li><a href="https://bikeleague.org/" class="text-primary hover:underline" target="_blank" rel="noopener">Bike League</a></li>
    <li><a href="https://www.peopleformobilityjustice.org/home" class="text-primary hover:underline" target="_blank" rel="noopener">People for Mobility Justice</a></li>
    <li><a href="http://ciclavalley.org/" class="text-primary hover:underline" target="_blank" rel="noopener">CiclaValley</a></li>
    <li><a href="https://www.lacriticalmass.org/" class="text-primary hover:underline" target="_blank" rel="noopener">LA Critical Mass</a></li>
    <li><a href="https://www.activesgv.org/" class="text-primary hover:underline" target="_blank" rel="noopener">ActiveSGV</a></li>
    <li><a href="https://esrbc.org/" class="text-primary hover:underline" target="_blank" rel="noopener">East Side Riders Bicycle Club</a></li>
    <li><a href="https://bikinginla.com/" class="text-primary hover:underline" target="_blank" rel="noopener">BikinginLA</a></li>
