    <li><a href="https://www.metro.net/riding/go-bike/" class="text-primary hover:underline" target="_blank" rel="noopener">Metro LA Bicycle Resource Site</a></li>
    <li><a href="https://bikeshare.metro.net/" class="text-primary hover:underline" target="_blank" rel="noopener">Metro LA Bike Share Program (E-bikes)</a></li>
    <li><a href="http://bike.lacity.org/" class="text-primary hover:underline" target="_blank" rel="noopener">LADOT Bicycle Program</a></li>
    <li><a href="https://la-bike.org/" class="text-primary hover:underline" target="_blank" rel="noopener">Los Angeles County Bicycle Coalition</a></li>
    <li><a href={url('/documents/labac/mobility-plan-2035.pdf')} class="text-primary hover:underline" target="_blank" rel="noopener">Mobility Plan 2035</a></li>
    <li><a href="http://visionzero.lacity.org/" class="text-primary hover:underline" target="_blank" rel="noopener">Vision Zero 2025</a></li>
    <li><a href="http://lagreatstreets.org/" class="text-primary hover:underline" target="_blank" rel="noopener">Great Streets Initiative</a></li>
  </ul>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Mobility Guides, Rules &amp; Regulations</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
