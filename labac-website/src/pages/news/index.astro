---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title="News & Updates" description="Latest news and updates from the Los Angeles Bicycle Advisory Committee.">
  {posts.length === 0 ? (
    <p class="text-text-muted">No posts yet. Check back soon!</p>
  ) : (
    <div class="space-y-6">
      {posts.map((post) => (
        <article class="border border-border rounded-lg p-6 hover:border-primary/30 transition-colors">
          <a href={`/news/${post.id}`} class="no-underline">
            <h2 class="text-xl font-semibold text-primary mb-1">{post.data.title}</h2>
            <time class="text-sm text-text-muted" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <p class="text-text-muted mt-2">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  )}
</PageLayout>
