---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Contact" description="Get in touch with the Los Angeles Bicycle Advisory Committee.">
  <p class="text-lg text-text-muted mb-6">
    We welcome public participation. Here's how to reach the committee.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Public Comment</h2>
  <p class="text-text-muted mb-4">
    Public comments can be sent to
    <a href="mailto:robkadota@gmail.com" class="text-primary hover:underline">robkadota@gmail.com</a>
    at least two hours prior to the meeting, with "Public Comment" in the subject line.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Attend a Meeting</h2>
  <p class="text-text-muted mb-4">
    LABAC meets on the first Tuesday of every even-numbered month at 7:00 PM.
  </p>
  <p class="text-text-muted mb-4">
    <strong>Location:</strong> Hollywood Neighborhood City Hall Community Room<br />
    6501 Fountain Avenue<br />
    Los Angeles, CA 90028
  </p>
  <p class="text-text-muted mb-4">
    Sub-committees meet during odd months. Check the <a href="/meetings" class="text-primary hover:underline">meetings page</a> for details.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Follow Us</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2">
    <li><a href="https://www.facebook.com/LosAngelesBicycleAdvisoryCommittee/" class="text-primary hover:underline" target="_blank" rel="noopener">Facebook</a></li>
    <li><a href="https://twitter.com/BicycleLACity/media" class="text-primary hover:underline" target="_blank" rel="noopener">Twitter / X</a></li>
    <li><a href="https://www.instagram.com/bicyclelacity/" class="text-primary hover:underline" target="_blank" rel="noopener">Instagram</a></li>
    <li><a href="https://www.youtube.com/channel/UC1TcSpr0y6BHDXJqAS9iaSQ" class="text-primary hover:underline" target="_blank" rel="noopener">YouTube</a></li>
  </ul>
</PageLayout>
