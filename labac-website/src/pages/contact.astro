---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Contact" description="Get in touch with the Los Angeles Bicycle Advisory Committee.">
  <p class="text-lg text-text-muted mb-6">
    We'd love to hear from you. Here's how to reach the committee.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Attend a Meeting</h2>
  <p class="text-text-muted mb-4">
    LABAC meets on the first Tuesday of every even-numbered month at 7:00 PM. Meetings are held at Los Angeles City Hall, 200 N Spring St, Los Angeles, CA 90012. The public is welcome.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Email</h2>
  <p class="text-text-muted mb-4">
    Contact information coming soon.
  </p>

  <h2 class="text-xl font-semibold text-primary mt-8 mb-3">Mailing Address</h2>
  <p class="text-text-muted">
    Los Angeles Bicycle Advisory Committee<br />
    c/o LADOT<br />
    200 N Spring St<br />
    Los Angeles, CA 90012
  </p>
</PageLayout>
